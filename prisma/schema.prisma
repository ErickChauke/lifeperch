// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  dailyDigest     Boolean          @default(true)
  accounts        Account[]
  sessions        Session[]
  timetableEvents TimetableEvent[]
  noteCollections NoteCollection[]
  notes           Note[]
  noteAttachments NoteAttachment[]
  dailyEntries    DailyEntry[]
  transactions    Transaction[]
  savingsGoals    SavingsGoal[]
  shoppingLists   ShoppingList[]
  shoppingItems   ShoppingItem[]
  wishlistCollections WishlistCollection[]
  wishlistItems   WishlistItem[]
  budgetPlans     BudgetPlan[]
  budgetItems     BudgetItem[]
  vaultCollections VaultCollection[]
  documents       Document[]
  literatureCollections LiteratureCollection[]
  literature      Literature[]
  habits          Habit[]
  habitLogs       HabitLog[]
  meals           Meal[]
  jobApplications JobApplication[]
  appStages       AppStage[]
  timelines       Timeline[]
  milestones      Milestone[]
  todoCollections TodoCollection[]
  todos           Todo[]
  createdAt       DateTime         @default(now())
}

model TimetableEvent {
  id           String    @id @default(cuid())
  userId       String
  title        String
  type         String
  color        String    @default("#378ADD")
  dayOfWeek    Int?
  startTime    String
  endTime      String
  isRecurring  Boolean   @default(true)
  specificDate DateTime?
  location     String?
  notes        String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
}

// A notebook: a titled folder that groups notes by topic. description optional.
model NoteCollection {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  notes       Note[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Note {
  id           String         @id @default(cuid())
  userId       String
  collectionId String
  title        String
  body         String         @default("") @db.Text
  bodyFormat   String         @default("markdown")
  tags         String[]       @default([])
  collection   NoteCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments  NoteAttachment[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// A file uploaded to Cloudinary and attached to a note. publicId is kept so the
// asset can be deleted when the attachment or its note is removed.
model NoteAttachment {
  id        String   @id @default(cuid())
  userId    String
  noteId    String
  name      String
  url       String
  publicId  String
  format    String?
  bytes     Int?
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyEntry {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  title      String?
  body       String   @default("") @db.Text
  bodyFormat String   @default("markdown")
  mood       Int      @default(5)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, date])
}

// One money event. Amounts are stored in cents (integer) to avoid float drift.
// type is "income" or "expense"; investing is carried by the "Investment" expense
// category and reframed on the dashboard as its own figure.
model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Int
  category    String
  description String?
  date        DateTime @db.Date
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// A savings target. Amounts in cents. monthlyAmount is the contribution that
// drives the time-to-goal estimate. Linked to a wishlist item by name only.
model SavingsGoal {
  id            String       @id @default(cuid())
  userId        String
  name          String
  targetAmount  Int          @default(0)
  currentAmount Int          @default(0)
  monthlyAmount Int          @default(0)
  budgetItems   BudgetItem[]
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// A titled shopping list scoped to one category (e.g. "Checkers run" / Groceries).
// Its basket is logged to the transaction log as one expense in this category.
model ShoppingList {
  id        String         @id @default(cuid())
  userId    String
  title     String
  category  String
  items     ShoppingItem[]
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// A planned purchase inside a list. price is the estimated unit price in cents;
// the category is inherited from the parent list.
model ShoppingItem {
  id        String       @id @default(cuid())
  userId    String
  listId    String
  name      String
  price     Int          @default(0)
  quantity  Int          @default(1)
  bought    Boolean      @default(false)
  list      ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

// A budget plan for a period: a monthly/weekly/custom envelope of expected money
// in and planned allocations out. periodType is "month"/"week"/"custom"; the
// startDate/endDate range drives the planned-vs-actual match against transactions.
model BudgetPlan {
  id         String       @id @default(cuid())
  userId     String
  title      String
  periodType String       @default("month")
  startDate  DateTime     @db.Date
  endDate    DateTime     @db.Date
  items      BudgetItem[]
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

// A line in a budget plan. kind is "income" (expected money in) or "expense"
// (a planned allocation). category matches the transaction categories so actual
// spend/income for the plan's period can be summed by category. amount in cents.
model BudgetItem {
  id        String       @id @default(cuid())
  userId    String
  planId    String
  kind      String       @default("expense")
  category  String
  title     String?
  amount    Int          @default(0)
  note      String?
  goalId    String?
  completed Boolean      @default(false)
  transactionId String?
  plan      BudgetPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  goal      SavingsGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

// A titled wishlist collection scoped to one category (e.g. "Photography kit").
model WishlistCollection {
  id          String         @id @default(cuid())
  userId      String
  title       String
  category    String?
  description String?
  items       WishlistItem[]
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// Something to buy someday, inside a collection. price in cents; priority is
// "high"/"medium"/"low"; the category is inherited from the parent collection.
// One tap turns it into a savings goal (linked by name).
model WishlistItem {
  id           String             @id @default(cuid())
  userId       String
  collectionId String
  name         String
  price        Int                @default(0)
  priority     String             @default("medium")
  note         String?
  completed    Boolean            @default(false)
  transactionId String?
  collection   WishlistCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

// A vault collection card: a titled folder that groups documents. description
// is optional; passwordHash is null for an open card or a salted hash for a
// card with its own password (a second lock inside the global vault PIN).
model VaultCollection {
  id           String     @id @default(cuid())
  userId       String
  title        String
  description  String?
  passwordHash String?
  resetToken   String?
  resetExpiry  DateTime?
  documents    Document[]
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// A vault document inside a collection card. The file lives in Cloudinary; url
// is the secure delivery URL and publicId is kept for deletion.
model Document {
  id           String          @id @default(cuid())
  userId       String
  collectionId String
  title        String
  url          String
  publicId     String
  format       String?
  bytes        Int?
  collection   VaultCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

// A literature topic: a titled folder that groups papers (e.g. "Thesis lit
// review"). description is optional.
model LiteratureCollection {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  papers      Literature[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// A literature review entry inside a topic. Either an uploaded PDF (fileUrl +
// publicId in Cloudinary) or an external link (url). status is
// "to-read"/"reading"/"read".
model Literature {
  id           String               @id @default(cuid())
  userId       String
  collectionId String
  title        String
  authors      String               @default("")
  year         Int?
  status       String               @default("to-read")
  url          String?
  fileUrl      String?
  publicId     String?
  notes        String               @default("") @db.Text
  notesFormat  String               @default("markdown")
  tags         String[]             @default([])
  collection   LiteratureCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

// A habit to keep. kind is "boolean" (done/not-done) or "count" (toward a daily
// target). target/unit only matter for countable habits. icon is a lucide name
// used as a label aid on the card. Archived habits leave the grid but keep history.
model Habit {
  id        String     @id @default(cuid())
  userId    String
  name      String
  kind      String     @default("boolean")
  target    Int        @default(1)
  unit      String?
  icon      String?
  archived  Boolean    @default(false)
  logs      HabitLog[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// One day's check-in for a habit. value is 0/1 for boolean habits, or the count
// reached for countable ones. One row per habit per day.
model HabitLog {
  id        String   @id @default(cuid())
  userId    String
  habitId   String
  date      DateTime @db.Date
  value     Int      @default(0)
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([habitId, date])
}

// A logged meal for a day. type is "breakfast"/"lunch"/"dinner"/"snack". time is
// an optional "HH:mm" clock string used to sort rows. calories are optional.
model Meal {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  type      String
  name      String
  time      String?
  calories  Int?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// An application in the pipeline (a job, bursary, scholarship, grant). status is
// the Kanban column: "to-apply"/"applied"/"interview"/"offer"/"outcome". A new
// application starts in "to-apply" - saved but not yet submitted. outcome carries
// the final result once in the outcome column: "accepted"/"rejected"/"withdrawn".
// value is an optional amount in cents (salary or award). url links the posting;
// deadline is the closing date, most useful while still to-apply.
model JobApplication {
  id           String     @id @default(cuid())
  userId       String
  organisation String
  position     String
  location     String?
  url          String?
  description  String?    @db.Text
  value        Int?
  status       String     @default("to-apply")
  outcome      String?
  appliedDate  DateTime?  @db.Date
  deadline     DateTime?  @db.Date
  stages       AppStage[]
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// A note in an application's history. label is the stage it belongs to (e.g.
// "Interview"); date is optional. Shown newest-first in the stage detail drawer.
model AppStage {
  id            String         @id @default(cuid())
  userId        String
  applicationId String
  label         String
  note          String         @default("")
  date          DateTime?      @db.Date
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// A named timeline track (e.g. "Career"/"Education"/"Personal"). Milestones
// optionally belong to one; the rail itself stays a single flat chronological line
// and the track reads as a label badge.
model Timeline {
  id         String      @id @default(cuid())
  userId     String
  name       String
  milestones Milestone[]
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([userId, name])
}

// A milestone on the timeline. status is "planned"/"in-progress"/"done"; overdue
// is computed from targetDate, never stored. timelineId is null for an untracked
// milestone.
model Milestone {
  id          String    @id @default(cuid())
  userId      String
  timelineId  String?
  title       String
  description String?
  targetDate  DateTime  @db.Date
  status      String    @default("planned")
  timeline    Timeline? @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// A scheduled task. It can be dateless (a flexible backlog item), tied to a
// specificDate, or recurring weekly on dayOfWeek (0 = Monday ... 6 = Sunday).
// startTime/endTime ("HH:MM") give it a time block on the timetable grid.
// priority is "low"/"normal"/"high"; status is "pending"/"done". Completion is a
// single status/completedAt: a recurring todo counts as done only on the day it
// was completed and reverts to pending the next day. linkedModule/linkedId point
// at any other module, realising the planned Reminder cross-link.
// A project: a titled folder that groups todos. description optional. Each
// project keeps its own list and calendar view.
model TodoCollection {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  todos       Todo[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Todo {
  id           String         @id @default(cuid())
  userId       String
  collectionId String
  title        String
  notes        String?
  priority     String         @default("normal")
  status       String         @default("pending")
  tags         String[]       @default([])
  isRecurring  Boolean        @default(false)
  dayOfWeek    Int?
  specificDate DateTime?      @db.Date
  startTime    String?
  endTime      String?
  linkedModule String?
  linkedId     String?
  linkedLabel  String?
  completedAt  DateTime?
  collection   TodoCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
